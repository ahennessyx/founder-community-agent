# ============================================================
# Founder Community Agent — Server Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Gmail OAuth credentials
# Get these from Google Cloud Console → APIs & Services → Credentials
GMAIL_CLIENT_ID=your_google_oauth_client_id_here
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here

# Admin identity (appears in email footer)
ADMIN_NAME=Your Name
ADMIN_EMAIL=you@yourdomain.com

# Community group name (appears in email footer)
GROUP_NAME=Founder Circle

# Server config
PORT=3001

# Frontend origin for CORS (no trailing slash)
FRONTEND_ORIGIN=http://localhost:8080

# Gmail MCP server URL
GMAIL_MCP_URL=https://gmail.mcp.claude.com/mcp
